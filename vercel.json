{
  "installCommand": "git clone --depth 1 --branch 3.41.6 https://github.com/flutter/flutter.git .flutter-sdk",
  "buildCommand": "bash ./scripts/vercel-build.sh",
  "outputDirectory": "build/web",
  "headers": [
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/flutter_bootstrap.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/flutter_service_worker.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/((?!_vercel|.*\\..*).*)",
      "destination": "/index.html"
    }
  ]
}
