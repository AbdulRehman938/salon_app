rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    // Social login profile docs: each user can only read/write their own doc.
    match /users/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId;
      allow list: if false;
      allow create, update: if isSignedIn() && request.auth.uid == userId;
      allow delete: if false;
    }

    // OTP docs used before login. Keep list blocked to reduce data exposure.
    // For stronger security, move OTP verification to Cloud Functions.
    match /emailOtpVerifications/{docId} {
      allow get: if true;
      allow list: if false;
      allow create, update: if true;
      allow delete: if false;
    }

    // Location search history: users can only write/read their own records.
    match /locationSearchHistory/{docId} {
      allow create: if isSignedIn() && request.resource.data.userUid == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userUid == request.auth.uid;
      allow list: if false;
      allow update, delete: if false;
    }

    // Salon catalog for dashboard cards.
    match /salons/{salonId} {
      allow get: if true;
      allow list: if true;
      allow create, update: if false;
      allow delete: if false;
    }

    // Booking checkout records: users can only create/read their own bookings.
    match /bookings/{bookingId} {
      allow create: if isSignedIn()
        && request.resource.data.bookingId is string
        && request.resource.data.salonId is string
        && request.resource.data.paymentMode == 'pay_at_salon'
        && request.resource.data.receipt.customer.uid == request.auth.uid;
      allow get: if isSignedIn() && resource.data.receipt.customer.uid == request.auth.uid;
      allow list: if isSignedIn();
      allow update: if isSignedIn()
        && resource.data.receipt.customer.uid == request.auth.uid
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          'status',
          'cancelledAt',
          'updatedAt',
        ])
        && request.resource.data.status == 'cancelled';
      allow delete: if false;
    }

    // Reviews: users can create and read reviews tied to their own uid.
    match /reviews/{reviewId} {
      allow create: if isSignedIn()
        && reviewId == (request.resource.data.bookingId + '_' + request.auth.uid)
        && request.resource.data.userUid == request.auth.uid
        && request.resource.data.salonId is string
        && request.resource.data.bookingId is string
        && exists(/databases/$(database)/documents/bookings/$(request.resource.data.bookingId))
        && get(/databases/$(database)/documents/bookings/$(request.resource.data.bookingId)).data.receipt.customer.uid == request.auth.uid
        && request.resource.data.rating is number
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5
        && request.resource.data.comment is string;
      allow get: if isSignedIn() && resource.data.userUid == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userUid == request.auth.uid;
      allow update, delete: if false;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
