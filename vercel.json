{
  "installCommand": "flutter pub get",
  "buildCommand": "flutter build web --release --dart-define=BREVO_API_KEY=$BREVO_API_KEY --dart-define=BREVO_SENDER_EMAIL=$BREVO_SENDER_EMAIL",
  "outputDirectory": "build/web",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
